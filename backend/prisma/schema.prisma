generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Felhasznalo {
  felhasznalo_id Int         @id @default(autoincrement())
  jelszo         String
  email          String      @unique
  felhasznalonev String      @unique
  Keres          Keres[]
  Kedvencek      Kedvencek[]
  Velemenyek     Velemeny[]
  Wishlist       Wishlist[]
  Notification   Notification[]

  @@index([email], name: "idx_email")
  @@index([felhasznalonev], name: "idx_felhasznalonev")
}

model WebAruhaz {
  webaruhaz_id Int          @id @default(autoincrement())
  url          String       @unique
  nev          String
  Keres        Keres[]
  Feljegyzes   Feljegyzes[]
  Arak         Arak[]

  @@index([url], name: "idx_url")
}

model Termek {
  termek_id  Int          @id @default(autoincrement())
  cim        String       @db.VarChar(500)
  tipus      Tipus
  szerzo     String?      @db.VarChar(255)
  isbn_issn  String?      @db.VarChar(20)
  boritokep  String?      @db.VarChar(500)
  Kedvencek  Kedvencek[]
  Feljegyzes Feljegyzes[]
  Velemenyek Velemeny[]

  @@index([tipus], name: "idx_tipus")
  @@index([szerzo], name: "idx_szerzo")
  @@index([isbn_issn], name: "idx_isbn_issn")
}

enum Tipus {
  konyv
  e_konyv
  manga
  kepregeny
  hangoskonyv
}

model Keres {
  keres_id       Int @id @default(autoincrement())
  felhasznalo_id Int
  webaruhaz_id   Int

  Felhasznalo Felhasznalo @relation(fields: [felhasznalo_id], references: [felhasznalo_id], onDelete: Cascade, onUpdate: Cascade)
  WebAruhaz   WebAruhaz   @relation(fields: [webaruhaz_id], references: [webaruhaz_id], onDelete: Cascade, onUpdate: Cascade)

  @@index([felhasznalo_id], name: "idx_felhasznalo")
  @@index([webaruhaz_id], name: "idx_webaruhaz")
}

model Kedvencek {
  kedvencek_id   Int @id @default(autoincrement())
  felhasznalo_id Int
  termek_id      Int

  Felhasznalo Felhasznalo @relation(fields: [felhasznalo_id], references: [felhasznalo_id], onDelete: Cascade, onUpdate: Cascade)
  Termek      Termek      @relation(fields: [termek_id], references: [termek_id], onDelete: Cascade, onUpdate: Cascade)
  Arak        Arak[]

  @@unique([felhasznalo_id, termek_id], name: "unique_kedvenc")
  @@index([felhasznalo_id], name: "idx_felhasznalo")
  @@index([termek_id], name: "idx_termek")
}

model Feljegyzes {
  feljegyzes_id Int @id @default(autoincrement())
  termek_id     Int
  webaruhaz_id  Int

  Termek      Termek        @relation(fields: [termek_id], references: [termek_id], onDelete: Cascade, onUpdate: Cascade)
  WebAruhaz   WebAruhaz     @relation(fields: [webaruhaz_id], references: [webaruhaz_id], onDelete: Cascade, onUpdate: Cascade)
  Ar_Tortenet Ar_Tortenet[]

  @@unique([termek_id, webaruhaz_id], name: "unique_feljegyzes")
  @@index([termek_id], name: "idx_termek")
  @@index([webaruhaz_id], name: "idx_webaruhaz")
}

model Arak {
  arak_id          Int     @id @default(autoincrement())
  kedvencek_id     Int
  webaruhaz_id     Int
  last_known_price Decimal @db.Decimal(10, 2)

  Kedvencek Kedvencek @relation(fields: [kedvencek_id], references: [kedvencek_id], onDelete: Cascade, onUpdate: Cascade)
  WebAruhaz WebAruhaz @relation(fields: [webaruhaz_id], references: [webaruhaz_id], onDelete: Cascade, onUpdate: Cascade)

  @@index([kedvencek_id], name: "idx_kedvencek")
  @@index([webaruhaz_id], name: "idx_webaruhaz")
}

model Ar_Tortenet {
  ar_id         Int      @id @default(autoincrement())
  feljegyzes_id Int
  ar            Decimal  @db.Decimal(10, 2)
  datum         DateTime @default(now())

  Feljegyzes Feljegyzes @relation(fields: [feljegyzes_id], references: [feljegyzes_id], onDelete: Cascade, onUpdate: Cascade)

  @@index([feljegyzes_id], name: "idx_feljegyzes")
  @@index([datum], name: "idx_datum")
}

model Velemeny {
  velemeny_id    Int      @id @default(autoincrement())
  felhasznalo_id Int
  termek_id      Int
  csillag        Int // star rating 1–5
  szoveg         String?  @db.Text
  datum          DateTime @default(now())

  Felhasznalo Felhasznalo @relation(fields: [felhasznalo_id], references: [felhasznalo_id], onDelete: Cascade, onUpdate: Cascade)
  Termek      Termek      @relation(fields: [termek_id], references: [termek_id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([felhasznalo_id, termek_id], name: "unique_velemeny")
  @@index([termek_id], name: "idx_termek")
  @@index([felhasznalo_id], name: "idx_felhasznalo")
}

model CachedPrice {
  isbn      String   @id @db.VarChar(20)
  data      Json
  updatedAt DateTime @default(now()) @updatedAt
}

model Wishlist {
  id              Int      @id @default(autoincrement())
  felhasznalo_id  Int
  book_id         String   @db.VarChar(255)
  title           String   @db.VarChar(500)
  author          String?  @db.VarChar(255)
  coverUrl        String?  @db.VarChar(500)
  isbn            String?  @db.VarChar(20)
  last_known_price Decimal? @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  
  Felhasznalo     Felhasznalo @relation(fields: [felhasznalo_id], references: [felhasznalo_id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([felhasznalo_id, book_id], name: "unique_wishlist")
  @@index([felhasznalo_id], name: "idx_wishlist_felhasznalo")
}

model Notification {
  notification_id Int      @id @default(autoincrement())
  felhasznalo_id  Int
  szoveg          String   @db.Text
  olvasott        Boolean  @default(false)
  datum          DateTime @default(now())

  Felhasznalo     Felhasznalo @relation(fields: [felhasznalo_id], references: [felhasznalo_id], onDelete: Cascade, onUpdate: Cascade)
  @@index([felhasznalo_id], name: "idx_notification_felhasznalo")
}
