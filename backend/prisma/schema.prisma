generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Felhasznalo {
  felhasznalo_id Int            @id @default(autoincrement())
  jelszo         String
  email          String         @unique
  felhasznalonev String         @unique
  profilkep      String?        @db.VarChar(500)
  szerepkor      Szerepkor      @default(USER)
  tiltva_eddig   DateTime?
  tiltas_oka     String?        @db.Text
  Keres          Keres[]
  Kedvencek      Kedvencek[]
  Velemenyek     Velemeny[]
  Kivansaglista  Kivansaglista[]
  Ertesites      Ertesites[]
  Konyvjelzok    Konyvjelzo[]

  ForumBejegyzes   ForumBejegyzes[]
  ForumHozzaszolas ForumHozzaszolas[]
  ForumSzavazat    ForumSzavazat[]
  ForumReakcio     ForumReakcio[]
  ForumHozzaszolasReakcio ForumHozzaszolasReakcio[]
  BejelentettJelentesek ForumReport[] @relation("ReportOrigin")

  @@index([email], name: "idx_email")
  @@index([felhasznalonev], name: "idx_felhasznalonev")
  @@index([tiltva_eddig], name: "idx_tiltva_eddig")
}

model WebAruhaz {
  webaruhaz_id Int          @id @default(autoincrement())
  url          String       @unique
  nev          String
  Keres        Keres[]
  Feljegyzes   Feljegyzes[]
  Arak         Arak[]

  @@index([url], name: "idx_url")
}

model Termek {
  termek_id  Int          @id @default(autoincrement())
  cim        String       @db.VarChar(500)
  tipus      Tipus
  isbn_issn  String?      @db.VarChar(20)
  boritokep  String?      @db.VarChar(500)
  Kedvencek  Kedvencek[]
  Feljegyzes Feljegyzes[]
  Velemenyek Velemeny[]
  Szerzok    Szerzo[]

  @@index([tipus], name: "idx_tipus")
  @@index([isbn_issn], name: "idx_isbn_issn")
}

model Szerzo {
  szerzo_id Int      @id @default(autoincrement())
  nev       String   @unique @db.VarChar(255)
  Termekek  Termek[]

  @@index([nev], name: "idx_szerzo_nev")
}

enum Tipus {
  konyv
  e_konyv
  manga
  kepregeny
  hangoskonyv
}

enum Szerepkor {
  USER
  ADMIN
}

model Keres {
  keres_id       Int @id @default(autoincrement())
  felhasznalo_id Int
  webaruhaz_id   Int

  Felhasznalo Felhasznalo @relation(fields: [felhasznalo_id], references: [felhasznalo_id], onDelete: Cascade, onUpdate: Cascade)
  WebAruhaz   WebAruhaz   @relation(fields: [webaruhaz_id], references: [webaruhaz_id], onDelete: Cascade, onUpdate: Cascade)

  @@index([felhasznalo_id], name: "idx_felhasznalo")
  @@index([webaruhaz_id], name: "idx_webaruhaz")
}

model Kedvencek {
  kedvencek_id   Int @id @default(autoincrement())
  felhasznalo_id Int
  termek_id      Int

  Felhasznalo Felhasznalo @relation(fields: [felhasznalo_id], references: [felhasznalo_id], onDelete: Cascade, onUpdate: Cascade)
  Termek      Termek      @relation(fields: [termek_id], references: [termek_id], onDelete: Cascade, onUpdate: Cascade)
  Arak        Arak[]

  @@unique([felhasznalo_id, termek_id], name: "unique_kedvenc")
  @@index([felhasznalo_id], name: "idx_felhasznalo")
  @@index([termek_id], name: "idx_termek")
}

model Feljegyzes {
  feljegyzes_id Int @id @default(autoincrement())
  termek_id     Int
  webaruhaz_id  Int

  Termek      Termek        @relation(fields: [termek_id], references: [termek_id], onDelete: Cascade, onUpdate: Cascade)
  WebAruhaz   WebAruhaz     @relation(fields: [webaruhaz_id], references: [webaruhaz_id], onDelete: Cascade, onUpdate: Cascade)
  Ar_Tortenet Ar_Tortenet[]

  @@unique([termek_id, webaruhaz_id], name: "unique_feljegyzes")
  @@index([termek_id], name: "idx_termek")
  @@index([webaruhaz_id], name: "idx_webaruhaz")
}

model Arak {
  arak_id          Int     @id @default(autoincrement())
  kedvencek_id     Int
  webaruhaz_id     Int
  utolso_ismert_ar Decimal @db.Decimal(10, 2)

  Kedvencek Kedvencek @relation(fields: [kedvencek_id], references: [kedvencek_id], onDelete: Cascade, onUpdate: Cascade)
  WebAruhaz WebAruhaz @relation(fields: [webaruhaz_id], references: [webaruhaz_id], onDelete: Cascade, onUpdate: Cascade)

  @@index([kedvencek_id], name: "idx_kedvencek")
  @@index([webaruhaz_id], name: "idx_webaruhaz")
}

model Ar_Tortenet {
  ar_id         Int      @id @default(autoincrement())
  feljegyzes_id Int
  ar            Decimal  @db.Decimal(10, 2)
  datum         DateTime @default(now())

  Feljegyzes Feljegyzes @relation(fields: [feljegyzes_id], references: [feljegyzes_id], onDelete: Cascade, onUpdate: Cascade)

  @@index([feljegyzes_id], name: "idx_feljegyzes")
  @@index([datum], name: "idx_datum")
}

model Velemeny {
  velemeny_id    Int      @id @default(autoincrement())
  felhasznalo_id Int
  termek_id      Int
  csillag        Int // star rating 1–5
  szoveg         String?  @db.Text
  datum          DateTime @default(now())

  Felhasznalo Felhasznalo @relation(fields: [felhasznalo_id], references: [felhasznalo_id], onDelete: Cascade, onUpdate: Cascade)
  Termek      Termek      @relation(fields: [termek_id], references: [termek_id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([felhasznalo_id, termek_id], name: "unique_velemeny")
  @@index([termek_id], name: "idx_termek")
  @@index([felhasznalo_id], name: "idx_felhasznalo")
}

model GyorsitotarazottAr {
  isbn      String   @id @db.VarChar(20)
  adatok    Json
  frissitve DateTime @default(now()) @updatedAt
}

model Kivansaglista {
  id               Int      @id @default(autoincrement())
  felhasznalo_id   Int
  konyv_id         String   @db.VarChar(255)
  cim              String   @db.VarChar(500)
  szerzo           String?  @db.VarChar(255)
  boritokep_url    String?  @db.VarChar(500)
  isbn             String?  @db.VarChar(20)
  utolso_ismert_ar Decimal? @db.Decimal(10, 2)
  letrehozva       DateTime @default(now())
  
  Felhasznalo      Felhasznalo @relation(fields: [felhasznalo_id], references: [felhasznalo_id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([felhasznalo_id, konyv_id], name: "unique_wishlist")
  @@index([felhasznalo_id], name: "idx_wishlist_felhasznalo")
}

model Ertesites {
  ertesites_id   Int      @id @default(autoincrement())
  felhasznalo_id Int
  szoveg         String   @db.Text
  olvasott       Boolean  @default(false)
  datum          DateTime @default(now())

  Felhasznalo    Felhasznalo @relation(fields: [felhasznalo_id], references: [felhasznalo_id], onDelete: Cascade, onUpdate: Cascade)
  @@index([felhasznalo_id], name: "idx_notification_felhasznalo")
}

model ForumBejegyzes {
  id              Int      @id @default(autoincrement())
  felhasznalo_id  Int
  konyv_id        String   @db.VarChar(255)
  konyv_cim       String   @db.VarChar(500)
  konyv_boritokep String?  @db.VarChar(500)
  cim             String   @db.VarChar(255)
  tartalom        String   @db.Text
  ertekeles       Int
  up_szavazatok   Int      @default(0)
  down_szavazatok Int      @default(0)
  letrehozva      DateTime @default(now())

  Felhasznalo      Felhasznalo @relation(fields: [felhasznalo_id], references: [felhasznalo_id], onDelete: Cascade)
  Hozzaszolasok    ForumHozzaszolas[]
  Szavazatok       ForumSzavazat[]
  Reakciok         ForumReakcio[]
  Jelentesek       ForumReport[]

  @@index([felhasznalo_id], name: "idx_forum_felhasznalo")
}

model ForumHozzaszolas {
  id              Int      @id @default(autoincrement())
  bejegyzes_id    Int
  felhasznalo_id  Int
  tartalom        String   @db.Text
  letrehozva      DateTime @default(now())

  Bejegyzes       ForumBejegyzes @relation(fields: [bejegyzes_id], references: [id], onDelete: Cascade)
  Felhasznalo     Felhasznalo    @relation(fields: [felhasznalo_id], references: [felhasznalo_id], onDelete: Cascade)
  Reakciok        ForumHozzaszolasReakcio[]
  Jelentesek      ForumReport[]

  @@index([bejegyzes_id], name: "idx_hozzaszolas_bejegyzes")
  @@index([felhasznalo_id], name: "idx_hozzaszolas_felhasznalo")
}

model ForumHozzaszolasReakcio {
  id              Int      @id @default(autoincrement())
  hozzaszolas_id  Int
  felhasznalo_id  Int
  emoji           String   @db.VarChar(10)

  Hozzaszolas      ForumHozzaszolas @relation(fields: [hozzaszolas_id], references: [id], onDelete: Cascade)
  Felhasznalo      Felhasznalo      @relation(fields: [felhasznalo_id], references: [felhasznalo_id], onDelete: Cascade)

  @@index([hozzaszolas_id], name: "idx_comment_reakcio_hozzaszolas")
}

model ForumReport {
  id              Int      @id @default(autoincrement())
  felhasznalo_id  Int      // reporter
  bejegyzes_id    Int?     // reported post
  hozzaszolas_id  Int?     // reported comment
  tipus           String   // vulgar, inappropriate, spam, etc.
  leiras          String?  @db.Text
  kep_url         String?  @db.VarChar(500)
  letrehozva      DateTime @default(now())
  kezelt          Boolean  @default(false)

  Bejelento       Felhasznalo       @relation("ReportOrigin", fields: [felhasznalo_id], references: [felhasznalo_id], onDelete: Cascade)
  Bejegyzes       ForumBejegyzes?   @relation(fields: [bejegyzes_id], references: [id], onDelete: Cascade)
  Hozzaszolas     ForumHozzaszolas? @relation(fields: [hozzaszolas_id], references: [id], onDelete: Cascade)

  @@index([felhasznalo_id], name: "idx_report_reporter")
  @@index([kezelt], name: "idx_report_status")
}

model ForumSzavazat {
  id              Int      @id @default(autoincrement())
  bejegyzes_id    Int
  felhasznalo_id  Int
  ertek           Int      // 1: up, -1: down

  Bejegyzes       ForumBejegyzes @relation(fields: [bejegyzes_id], references: [id], onDelete: Cascade)
  Felhasznalo     Felhasznalo    @relation(fields: [felhasznalo_id], references: [felhasznalo_id], onDelete: Cascade)

  @@unique([bejegyzes_id, felhasznalo_id], name: "unique_forum_szavazat")
}

model ForumReakcio {
  id              Int      @id @default(autoincrement())
  bejegyzes_id    Int
  felhasznalo_id  Int
  emoji           String   @db.VarChar(10)

  Bejegyzes       ForumBejegyzes @relation(fields: [bejegyzes_id], references: [id], onDelete: Cascade)
  Felhasznalo     Felhasznalo    @relation(fields: [felhasznalo_id], references: [felhasznalo_id], onDelete: Cascade)

  @@index([bejegyzes_id], name: "idx_reakcio_bejegyzes")
}

model CensoredWord {
  id    Int    @id @default(autoincrement())
  word  String @unique @db.VarChar(255)
}

model Konyvjelzo {
  id             Int      @id @default(autoincrement())
  felhasznalo_id Int
  konyv_id       String   @db.VarChar(255)
  cim            String   @db.VarChar(500)
  szerzo         String?  @db.VarChar(255)
  boritokep_url  String?  @db.VarChar(500)
  oldalszam      Int      @default(0)
  max_oldalszam  Int?
  idezet         String?  @db.VarChar(255)
  frissitve      DateTime @default(now()) @updatedAt
  letrehozva     DateTime @default(now())

  Felhasznalo    Felhasznalo @relation(fields: [felhasznalo_id], references: [felhasznalo_id], onDelete: Cascade)

  @@unique([felhasznalo_id, konyv_id], name: "unique_konyvjelzo")
  @@index([felhasznalo_id], name: "idx_konyvjelzo_felhasznalo")
}
